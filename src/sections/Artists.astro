---
import SectionHeader from '@/components/SectionHeader.astro'
import { ARTISTS } from '@/consts/artists'
import type { ArtistTier } from '@/types/artists'

const tierConfig: Record<
  ArtistTier,
  { nameClass: string; rowClass: string; separatorClass: string }
> = {
  1: {
    nameClass:
      'font-cinzel text-xl font-black tracking-[0.12em] text-theme-cream sm:text-5xl md:text-6xl cursor-crosshair',
    rowClass: 'flex flex-wrap justify-center gap-x-5 gap-y-2 sm:gap-x-8',
    separatorClass: 'text-theme-gold/50 font-cinzel text-4xl sm:text-5xl md:text-6xl',
  },
  2: {
    nameClass:
      'font-cinzel text-xl font-bold tracking-[0.18em] text-theme-cream/90 sm:text-2xl md:text-4xl cursor-crosshair',
    rowClass: 'flex flex-wrap justify-center gap-x-4 gap-y-1 sm:gap-x-7',
    separatorClass: 'text-theme-gold/40 font-cinzel text-xl sm:text-2xl md:text-3xl',
  },
  3: {
    nameClass:
      'font-cinzel text-xs font-semibold tracking-[0.22em] text-theme-cream/70 sm:text-sm md:text-2xl cursor-crosshair',
    rowClass: 'flex flex-wrap justify-center gap-x-3 gap-y-1 sm:gap-x-5',
    separatorClass: 'text-theme-gold/30 font-cinzel text-xs sm:text-sm md:text-base',
  },
}

const tiers = ([1, 2, 3] as ArtistTier[]).map((tier) => ({
  tier,
  artists: ARTISTS.filter((a) => a.tier === tier),
  config: tierConfig[tier],
}))
---

<section
  id="artists"
  class="relative w-full overflow-hidden px-4 py-20 sm:px-6 lg:py-28"
  aria-labelledby="artists-title"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-theme-gold/30 to-transparent"
  >
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-72 bg-[radial-gradient(ellipse_at_top,_var(--color-theme-gold)_0%,_transparent_70%)] opacity-[0.05]"
  >
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col items-center">
    <SectionHeader
      titleId="artists-title"
      title="ARTISTAS"
      subtitle="Los artistas que harán inolvidable la velada del año VI"
      subtitleClass="mb-14 max-w-xl tracking-[0.25em] sm:mb-16 sm:text-sm"
    />

    <!-- Festival poster (desktop / dispositivos con hover) -->
    <div
      class="poster hidden w-full max-w-5xl text-center md:block"
      role="list"
      aria-label="Cartel de artistas"
    >
      {
        tiers.map(({ tier, artists, config }, tierIndex) => (
          <>
            <div
              role="listitem"
              class:list={['tier-row', config.rowClass, 'items-baseline']}
              style={`animation-delay: ${tierIndex * 140}ms`}
            >
              {artists.map((artist, i) => (
                <>
                  <span
                    class:list={['artist-name', config.nameClass]}
                    data-artist-name
                    data-image={artist.image}
                  >
                    {artist.name}
                  </span>
                  {i < artists.length - 1 && (
                    <span
                      aria-hidden="true"
                      class:list={['separator leading-none', config.separatorClass]}
                    >
                      ·
                    </span>
                  )}
                </>
              ))}
            </div>

            {tierIndex < tiers.length - 1 && (
              <div
                aria-hidden="true"
                class="tier-divider my-6 flex items-center gap-4 sm:my-8"
                style={`animation-delay: ${tierIndex * 140 + 100}ms`}
              >
                <div class="h-px flex-1 bg-linear-to-r from-transparent via-theme-gold/25 to-transparent" />
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 18 18"
                  fill="none"
                  class="shrink-0 opacity-40"
                  aria-hidden="true"
                >
                  <path
                    d="M9 0 L10.5 7.5 L18 9 L10.5 10.5 L9 18 L7.5 10.5 L0 9 L7.5 7.5 Z"
                    fill="var(--color-theme-gold)"
                  />
                </svg>
                <div class="h-px flex-1 bg-linear-to-r from-transparent via-theme-gold/25 to-transparent" />
              </div>
            )}
          </>
        ))
      }
    </div>

    <!-- Tarjetas (móvil / dispositivos táctiles) -->
    <ul
      class="grid w-full grid-cols-2 gap-x-4 gap-y-7 sm:gap-x-6 md:hidden"
      aria-label="Cartel de artistas"
    >
      {
        ARTISTS.map((artist, i) => {
          const isHeadliner = artist.tier === 1
          return (
            <li
              class:list={[
                'artist-card flex flex-col items-center',
                isHeadliner && 'col-span-2',
              ]}
              style={`animation-delay: ${i * 80}ms`}
            >
              <div
                class:list={[
                  'w-full overflow-hidden rounded-xl border border-theme-gold/25 shadow-lg shadow-black/40',
                  isHeadliner ? 'aspect-[16/10]' : 'aspect-[3/4]',
                ]}
              >
                <img
                  src={artist.image}
                  alt={`Foto de ${artist.name}`}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                />
              </div>
              <span
                class:list={[
                  'mt-3 text-center font-cinzel font-bold text-theme-cream',
                  isHeadliner ? 'text-lg tracking-[0.14em]' : 'text-sm tracking-[0.1em]',
                ]}
              >
                {artist.name}
              </span>
            </li>
          )
        })
      }
    </ul>
  </div>

  <!-- Floating image that follows the cursor on artist hover -->
  <div class="artist-reveal hidden md:block" data-artist-reveal aria-hidden="true">
    <img data-artist-reveal-img src="" alt="" decoding="async" loading="lazy" />
  </div>
</section>

<style>
  .tier-row,
  .tier-divider,
  .artist-card {
    opacity: 0;
    animation: fade-up 0.65s ease forwards;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .artist-name {
    display: inline-block;
    text-shadow: 0 0 40px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    transition:
      color 0.25s ease,
      text-shadow 0.25s ease;
  }

  .artist-name:hover {
    color: var(--color-theme-gold);
    text-shadow: 0 0 60px color-mix(in srgb, var(--color-theme-gold) 50%, transparent);
  }

  .artist-reveal {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 30;
    width: clamp(150px, 18vw, 260px);
    aspect-ratio: 3 / 4;
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.55),
      0 0 50px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
  }

  .artist-reveal img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .artist-reveal {
      display: none;
    }

    .tier-row,
    .tier-divider,
    .artist-card {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .artist-name {
      transition: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  // GSAP cargado vía CDN ESM (mismo enfoque que Leaflet en Map.astro)
  // @ts-expect-error - módulo remoto sin tipos
  import gsap from 'https://cdn.jsdelivr.net/npm/gsap@3.13.0/+esm'

  function initArtistReveal() {
    const reveal = $<HTMLElement>('[data-artist-reveal]')
    const img = $<HTMLImageElement>('[data-artist-reveal-img]')
    const names = $$<HTMLElement>('[data-artist-name]')
    if (!reveal || !img || names.length === 0) return

    // Respetar la preferencia de movimiento reducido
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
    if (reduceMotion.matches) return

    // En dispositivos táctiles (sin hover) se usan las tarjetas, no el efecto
    if (window.matchMedia('(hover: none), (pointer: coarse)').matches) return

    // Movimiento suave del cursor con retardo (lag)
    const xTo = gsap.quickTo(reveal, 'x', { duration: 0.55, ease: 'power3' })
    const yTo = gsap.quickTo(reveal, 'y', { duration: 0.55, ease: 'power3' })

    let activeSrc = ''

    // Si una imagen no carga, ocultamos el marco para no mostrar una caja vacía
    img.addEventListener('error', () => {
      gsap.set(reveal, { opacity: 0 })
    })

    const show = (el: HTMLElement) => {
      const src = el.getAttribute('data-image')
      if (!src) return
      if (src !== activeSrc) {
        img.src = src
        activeSrc = src
      }
      // overwrite 'auto' => solo sobrescribe opacity/scale, NUNCA los tweens de x/y
      gsap.to(reveal, {
        opacity: 1,
        scale: 1,
        duration: 0.5,
        ease: 'power3.out',
        overwrite: 'auto',
      })
    }

    const hide = () => {
      gsap.to(reveal, {
        opacity: 0,
        scale: 0.85,
        duration: 0.4,
        ease: 'power3.out',
        overwrite: 'auto',
      })
    }

    const move = (e: PointerEvent) => {
      xTo(e.clientX)
      yTo(e.clientY)
    }

    // Estado inicial: centrado sobre el cursor (xPercent/yPercent) + oculto
    gsap.set(reveal, { scale: 0.85, opacity: 0, xPercent: -50, yPercent: -50 })

    names.forEach((name) => {
      name.addEventListener('pointerenter', (e) => {
        xTo.tween.progress(1)
        yTo.tween.progress(1)
        xTo((e as PointerEvent).clientX)
        yTo((e as PointerEvent).clientY)
        show(name)
      })
      name.addEventListener('pointermove', move as EventListener)
      name.addEventListener('pointerleave', hide)
    })
  }

  initArtistReveal()
  document.addEventListener('astro:page-load', initArtistReveal)
</script>
